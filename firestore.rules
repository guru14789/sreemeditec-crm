
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Access Control: Authenticated users can read/write; UI handles role-based visibility
    match /{collectionName}/{docId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // Specific validation for tasks (allow admins/authenticated users to delete)
    match /tasks/{taskId} {
      allow create, update, delete: if isAuthenticated() && 
        request.resource.data.title is string &&
        request.resource.data.status in ['To Do', 'In Progress', 'Review', 'Done'];
    }
  }
}
