
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Strict Control: Only the Master Admin can delete data
    match /{collectionName}/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if request.auth.token.email == 'sreekumar.career@gmail.com';
    }

    // Specific validation for tasks (example of more granular control)
    match /tasks/{taskId} {
      allow create, update: if isAuthenticated() && 
        request.resource.data.title is string &&
        request.resource.data.status in ['To Do', 'In Progress', 'Review', 'Done'];
    }
  }
}
